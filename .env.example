# Expense Tracker API - Environment variables
# Copy this file to .env and fill in your values

# PostgreSQL (Supabase) - use the "Connection string" from Supabase Dashboard → Settings → Database
# Format: postgresql://postgres.[project-ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# JWT secret - use a long random string in production (e.g. openssl rand -hex 32)
JWT_SECRET=change_me_to_a_long_random_string

# Optional: JWT expiry (default: 7d)
# JWT_EXPIRY=7d

# Server port (default: 5000)
PORT=5000

# Optional: set to production when deploying
# NODE_ENV=production

# Email (Resend API - no SMTP, works on Render)
# Set to true to enable welcome + reminder emails
EMAIL_ENABLED=false

# Resend API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Sender address (use verified domain in Resend, or onboarding@resend.dev for testing)
MAIL_FROM=Trackify <onboarding@resend.dev>

# App URL for email links
APP_URL=https://trackifyapp.space
