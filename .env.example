# Expense Tracker API - Environment variables
# Copy this file to .env and fill in your values

# PostgreSQL (Neon) - replace YOUR_NEW_PASSWORD_HERE with your actual password
DATABASE_URL=postgresql://YOUR_NEW_PASSWORD_HERE@ep-holy-sound-aihvv60c-pooler.c-4.us-east-1.aws.neon.tech/expense-tracker?sslmode=require

# JWT secret - use a long random string in production (e.g. openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Optional: JWT expiry (default: 7d)
# JWT_EXPIRY=7d

# Server port (default: 5000)
PORT=5000

# Optional: set to production when deploying
# NODE_ENV=production
