# Expense Tracker API - Environment variables
# Copy this file to .env and fill in your values

# PostgreSQL (Neon) - use the "Connection string" from Neon dashboard (NOT the REST/API URL)
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-holy-sound-aihvv60c-pooler.c-4.us-east-1.aws.neon.tech/expense-tracker?sslmode=require

# JWT secret - use a long random string in production (e.g. openssl rand -hex 32)
JWT_SECRET=200017b62f8a34846584bbaef1d88a050186edcfe406ed38a5523898407990163def1db3f234c36d8b8519c009847c5be07cdcce99768931b7089c6fb1cbacae



# Optional: JWT expiry (default: 7d)
# JWT_EXPIRY=7d

# Server port (default: 5000)
PORT=5000

# Optional: set to production when deploying
# NODE_ENV=production

# Email (Resend API - no SMTP, works on Render)
# Set to true to enable welcome + reminder emails
EMAIL_ENABLED=false

# Resend API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Sender address (use verified domain in Resend, or onboarding@resend.dev for testing)
MAIL_FROM=Trackify <onboarding@resend.dev>
